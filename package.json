    "build:css": "sass scss/style.scss style.css",
    "format": "prettier --write \"**/*.{html,css,scss,js}\"",
    "lint": "eslint \"**/*.js\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guibndz/spend-wise.git"
  },
